# ==========================================
# Machine Learning Data & Models
# ==========================================
# Ignore raw and processed data files
*.csv
*.tsv
*.dat
*.json
data/raw/*
data/processed/*
datasets/

# Allow keeping the empty data folders in the repository
!data/raw/.gitkeep
!data/processed/.gitkeep

# Ignore trained model weights and checkpoints
*.h5
*.hdf5
*.pt
*.pth
*.pkl
*.pickle
*.onnx
*.joblib
models/*
checkpoints/*

# Allow keeping the empty models folder
!models/.gitkeep

